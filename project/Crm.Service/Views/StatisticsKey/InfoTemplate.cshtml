@inherits Crm.Library.Modularization.CrmViewUserControl
@using Crm.Library.Globalization.Extensions

<!-- ko if: $root.lookups.statisticsKeyProductType ||
$root.lookups.statisticsKeyMainAssembly ||
$root.lookups.statisticsKeySubAssembly ||
$root.lookups.statisticsKeyAssemblyGroup ||
$root.lookups.statisticsKeyFaultImage ||
$root.lookups.statisticsKeyRemedy ||
$root.lookups.statisticsKeyCause ||
$root.lookups.statisticsKeyWeighting ||
$root.lookups.statisticsKeyCauser -->
<div class="pmb-block">
	<div class="d-flex">
		<div class="flex-column flex-fill">
			<!-- ko if: showHeader -->
			<div class="pmbb-header">
				<h2>
					<i class="zmdi zmdi-assignment m-r-5"></i>
					<span>@(Html.Localize("StatisticsKey"))</span>
				</h2>
			</div>
			<!-- /ko -->
			<div class="pmbb-body p-l-30">
				<div class="pmbb-view">
					@await Html.PartialAsync("DescriptionList")
				</div>
			</div>
		</div>
		<div class="d-flex flex-auto">
			<ul class="actions" data-bind="visible: condition">
				<li class="dropdown">
					<!-- ko requiredPermission: { name: 'Edit', group: 'StatisticsKey' } -->
					<a class="statisticskey-edit" href="#" data-bind="attr: { 'data-route': getEditRoute }, tooltip: true" data-toggle="modal" data-target="#lgModal" title="@(Html.Localize("Edit"))"><i class="zmdi zmdi-edit"></i></a>
					<!-- /ko -->
				</li>
			</ul>
		</div>
	</div>
</div>
<!-- /ko -->