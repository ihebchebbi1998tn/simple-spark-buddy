@using Crm.Library.Globalization.Extensions
@inherits Crm.Library.Modularization.CrmViewUserControl

<div id="{{Id}}" class="lv-item media"
     data-bind="infiniteScrollItem: { index: $index(), array: $parent.items }, visible: $parent.isVisible($data)">
	@await Html.PartialAsync("GenericListBulkControl")
	<div class="media-body">
		<div class="row">
			<div class="col-sm-4">
				@await Html.PartialAsync("../ServiceOrderMaterialList/MaterialItemTemplateDetails")
			</div>
			<div class="col-xs-11 col-sm-7">
				<div class="row">
					<span class="col-xs-2 p-r-5 visible-xs">@(Html.Localize("EstimatedQty")):</span>
					<span class="col-xs-5 col-sm-5 text-right p-r-5 p-l-5"
					      data-bind="money: $parent.getEstimatedQuantity($data)"></span>
					<span class="col-xs-4 col-sm-7 p-0 text-nowrap">
						<span data-bind="lookupValue: QuantityUnitKey, lookups: $root.lookups.quantityUnits"></span>
						<span class="hidden-xs c-black p-l-5">(@(Html.Localize("EstimatedQty")))</span>
					</span>
				</div>
				<div class="row">
					<span class="col-xs-2 p-r-5 visible-xs">@(Html.Localize("ActualQty")):</span>
					<span class="col-xs-5 col-sm-5 text-right p-r-5 p-l-5"
					      data-bind="money: $parent.getActualQuantity($data)"></span>
					<span class="col-xs-4 col-sm-7 p-0 text-nowrap">
						<span data-bind="lookupValue: QuantityUnitKey, lookups: $root.lookups.quantityUnits"></span>
						<span class="hidden-xs c-black p-l-5">(@(Html.Localize("ActualQty")))</span>
					</span>
				</div>
				<!-- ko if: $parent.showActualQuantityOfOtherDispatches() -->
				<div class="row">
					<span class="col-xs-2 p-r-5 visible-xs">@(Html.Localize("OtherDispatches")):</span>
					<span class="col-xs-5 col-sm-5 text-right p-r-5 p-l-5"
					      data-bind="money: $parent.getActualQuantityOfOtherDispatches($data)"></span>
					<span class="col-xs-4 col-sm-7 p-0 text-nowrap">
						<span data-bind="lookupValue: QuantityUnitKey, lookups: $root.lookups.quantityUnits"></span>
						<span class="hidden-xs c-black p-l-5">(@(Html.Localize("OtherDispatches")))</span>
					</span>
				</div>
				<!-- /ko -->
			</div>
		</div>
		@await Html.PartialAsync("../ServiceOrderMaterialList/MaterialItemTemplateActions")
	</div>
</div>
