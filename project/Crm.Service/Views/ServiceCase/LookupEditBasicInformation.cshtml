@using Crm.Library.Extensions
@inherits Crm.Library.Modularization.CrmViewUserControl
<!-- ko if: $root.table === "CrmService_ServiceCaseStatus" -->
<form-element params="value: Groups, caption: 'Groups', type: 'select'">
	@{ var groups = new[] { "Preparation", "InProgress", "Closed" }; }
	<select class="form-control" multiple="multiple" data-bind="select2autocompleter: { data: @(groups.OrderBy(x => ResourceManager.GetTranslation(x) ?? x).Select(x => new { Key = x, Value = ResourceManager.GetTranslation(x) ?? x }).SerializeToJson()), optionsText: 'Value', optionsValue: 'Key', placeholder: Helper.String.getTranslatedString('Unspecified') }, selectedOptions: ko.pureComputed({ read: () => (value() || '').split(',').filter(Boolean), write: (newValue) => value(newValue.join(',') || null) });">
	</select>
</form-element>
<form-element params="value: SettableStatuses, caption: 'SettableStatuses', type: 'select'">
	<select class="form-control" multiple="multiple" data-bind="select2autocompleter: { data: ko.pureComputed({ read: () => (value() || '').split(',').filter(Boolean), write: (newValue) => value(newValue.join(',') || null) }), autocompleteOptions: { customFilter: (query, term) => Helper.Lookup.queryLookup(query.filter(it => it.Key !== this.key, { key: $root.lookup().Key() }), term), table: 'CrmService_ServiceCaseStatus', mapDisplayObject: Helper.Lookup.mapLookupForSelect2Display, getElementByIdQuery: Helper.Lookup.getLookupByKeyQuery }, placeholder: Helper.String.getTranslatedString('Unspecified') }">
	</select>
</form-element>
<!-- /ko -->