@inherits Crm.Library.Modularization.CrmViewUserControl

<div class="col-sm-12">
	<div class="row">
		<div class="col-sm-6">
			<servicecase-dashboard-list></servicecase-dashboard-list>
		</div>
		<div class="col-sm-6">
			<div class="row">
				<div class="col-sm-12">
					<mini-chart params="caption: window.Helper.String.getTranslatedString('EntityWithoutActivityDays').replace('{0}', window.Helper.String.getTranslatedString('ServiceCases')).replace('{1}', '3'), count: Helper.ServiceCase.getServiceCasesWithoutActivityCount, color: 'red', url: '#/Crm.Service/ServiceCaseList/IndexTemplate?&bookmark=%7B%22Key%22%3A%22EntityWithoutActivityDays3%22%7D'"></mini-chart>
				</div>
				<div class="col-sm-12">
					<mini-chart params="caption: 'ServiceCasesWithoutAssignment', count: Helper.ServiceCase.getServiceCasesWithoutAssignmentCount, color: 'red', url: '#/Crm.Service/ServiceCaseList/IndexTemplate?&bookmark=%7B%22Key%22%3A%22ServiceCasesWithoutAssignment%22%7D'"></mini-chart>
				</div>
				<div class="col-sm-12">
					<count-widget params="caption: window.Helper.String.getTranslatedString('ServiceCases') + ' ' + '(' + window.Helper.String.getTranslatedString('Priority') + ')', options: window.Helper.ServiceCase.getCountWidgetOptions"></count-widget>
				</div>
			</div>
		</div>
	</div>
</div>
