@inherits Crm.Library.Modularization.CrmViewUserControl
@using Crm.Library.Globalization.Extensions
@using Crm.Library.Modularization.Extensions

<div role="tabpanel" class="tab-pane animated fadeIn" id="tab-error" data-bind="with: tabs()['tab-error']">
	<div class="content-header placeholder">
		<div class="lv-header-alt generic-list-header main-section listview">
			<div class="card-header d-flex flex-auto">
				<div class="caption d-flex flex-auto">
					<h2>&nbsp;</h2>
				</div>
				<ul class="top-menu section-menu actions generic-list-actions">
					<li data-bind="visible: true, tooltip: true" data-placement="bottom">
						<a id="open-generic-list-filter" data-trigger="#right-nav" href="#" data-route="@("Crm.Service/ServiceOrderErrorTypeList/FilterTemplate")">
							<i class="tm-icon zmdi zmdi-filter-list"></i>
							<div class="small">@(Html.Localize("Filter"))</div>
						</a>
					</li>
				</ul>
			</div>
		</div>
		<floating-action-button params="position: 'top', showWhenDropdownIsToggled: true">
			@Html.PluginRenderActions("ServiceOrderErrorTypeTabPrimaryAction")
		</floating-action-button>
	</div>
	<ul class="top-menu">
		@Html.PluginRenderActions("ServiceOrderErrorTabTopMenu")
	</ul>
	<empty-state-box params="mood: 'sad', title: 'Error', text: 'ThereAreNoErrorTypes'" data-bind="visible: items().length === 0 && !isFiltered()">
	</empty-state-box>
	@Html.PluginRenderActions("MaterialGenericListResourceExtensions")
	<div class="generic-list listview lv-bordered">
		<div class="lv-body">
			<div class="panel-group p-l-20 p-r-20" role="tablist" id="accordion-errorTypes">
				<div data-bind="foreach: items">
					@await Html.PartialAsync("GenericListItemGroup")
					@await Html.PartialAsync("../ServiceOrderErrorTypeList/MaterialItemTemplate")
				</div>
			</div>
			<!-- ko if: items().length === 0 && isFiltered() -->
			<div id="generic-list-empty-state" class="lv-item media">
				<div class="row media-body">
					<div class="col-xs-12">
						<small class="lv-small">@(Html.Localize("NoRecordsForSearchCriteria"))</small>
					</div>
				</div>
			</div>
			<!-- /ko -->
		</div>
	</div>
	@await Html.PartialAsync("Material/GenericListPreloader")
</div>