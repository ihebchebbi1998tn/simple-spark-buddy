@inherits Crm.Library.Modularization.CrmViewUserControl
@using Crm.Library.Globalization.Extensions
@using Crm.Library.Modularization.Extensions

<collapsible-block params="id: 'service-order-extended'" class="morph">
	<collapsible-block-header params="customCss: 'bg-white', swapIcons: true">
		<span>@(Html.Localize("ServiceOrder")) - @(Html.Localize("ExtendedData"))</span>
	</collapsible-block-header>
	<collapsible-block-content params="context: { serviceOrderTemplate: $root.serviceOrderTemplate }">
		<!-- ko with: serviceOrderTemplate -->
		@Html.PluginRenderActions("ServiceOrderTemplateCreateFormServiceOrderExtendedTop")
		<div class="flex-input-row">
			<div>
				<form-element id="PreferredTechnicianUsergroupKey" params="value: PreferredTechnicianUsergroupKey, caption: 'PreferredTechnicianUsergroup', type: 'select2'">
					<select class="form-control" data-bind="select2autocompleter: { data: value, autocompleteOptions: { orderBy: ['Name'], table: 'Main_Usergroup', customFilter: Helper.User.filterUsergroupQuery, mapDisplayObject: Helper.User.mapUsergroupForSelect2Display, getElementByIdQuery: Helper.User.filterUsergroupQueryById, placeholder: $parent.placeholder, onSelect: function(value) { $parent.PreferredTechnicianUsergroupObject(value); } } }">
					</select>
				</form-element>
			</div>
			<div>
				<form-element id="PreferredTechnician" params="value: PreferredTechnician, caption: 'PreferredTechnician', type: 'select2'">
					<select class="form-control" data-bind="select2autocompleter: { data: value, autocompleteOptions: { orderBy: ['LastName'], table: 'Main_User', mapDisplayObject: Helper.User.mapForSelect2Display, customFilter: (query, term) => $root.preferredTechnicianFilter($parent.PreferredTechnicianUsergroupKey(), query, term), placeholder: $parent.placeholder, onSelect: function(value) { $parent.PreferredTechnicianUser(value ? value.asKoObservable() : null); } } }">
					</select>
				</form-element>
			</div>
		</div>
		<div class="flex-input-row">
			<div>
				<form-element id="UserGroupKey" params="value: UserGroupKey, caption: 'ResponsibleUser-Usergroup', type: 'select2'">
					<select class="form-control" data-bind="select2autocompleter: { data: value, autocompleteOptions: { orderBy: ['Name'], table: 'Main_Usergroup', customFilter: Helper.User.filterUsergroupQuery, mapDisplayObject: function(ug) { return { id: ug.Id, text: ug.Name }; }, placeholder: placeholder } }">
					</select>
				</form-element>
			</div>
			<div>
				<form-element id="ResponsibleUser" params="value: ResponsibleUser, caption: 'ResponsibleUser', type: 'select2'">
					<select class="form-control" data-bind="select2autocompleter: { data: value, autocompleteOptions: { orderBy: ['LastName'], table: 'Main_User', mapDisplayObject: Helper.User.mapForSelect2Display, placeholder: placeholder, customFilter: function (query, term) { return Helper.User.filterUserQuery(query, term, $parent.UserGroupKey()); } } }">
					</select>
				</form-element>
			</div>
		</div>
		@Html.PluginRenderActions("ServiceOrderTemplateCreateFormServiceOrderExtendedBottom")
		<!-- /ko -->
	</collapsible-block-content>
</collapsible-block>