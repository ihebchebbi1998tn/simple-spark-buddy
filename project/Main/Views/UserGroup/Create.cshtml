@using Crm.Library.Modularization.Extensions
@inherits Crm.Library.Modularization.CrmViewUserControl
@using Crm.Library.Modularization.Extensions

<div class="container">
	<div class="card">
		<div class="card-body card-padding">
			<form role="form" data-bind="with: userGroup">
				<form-element id="Name" params="value: Name, caption: 'Name', type: 'text'"></form-element>
				@Html.PluginRenderActions("UserGroupCreateForm")
				<div class="row">
					<div class="col-md-6">
						<form-element id="Members" params="value: Members, caption: 'Users', type: 'select'">
							<select class="form-control" name="Members" multiple="multiple"
							        data-bind="select2autocompleter: $root.membersSelect2autocompleter(), selectedOptions: $root.Members">
							</select>
						</form-element>
					</div>
				</div>
				@Html.PluginRenderActions("UserGroupCreate")
			</form>
		</div>
		@await Html.PartialAsync("CreateFormFooter")
	</div>
</div>