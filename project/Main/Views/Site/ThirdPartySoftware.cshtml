<div class="container">
	<div class="card">
		<div class="card-header ch-alt">
			<h2>Third-Party Software</h2>
		</div>
		<div class="table-responsive">
			<table class="table table-condensed">
				<thead>
				<tr>
					<th>Name</th>
					<th>Version</th>
					<th>License</th>
					<th>Author</th>
				</tr>
				</thead>
				<tbody data-bind="foreach: items">
				<tr>
					<td>
						<a href="{{url}}" target="_blank">{{name}}</a>
					</td>
					<td>{{version}}</td>
					<td>
						<a href="{{licenseUrl}}" target="_blank">{{licenseType}}</a>
					</td>
					<td>{{author}}</td>
				</tr>
				</tbody>
			</table>
		</div>
	</div>
</div>