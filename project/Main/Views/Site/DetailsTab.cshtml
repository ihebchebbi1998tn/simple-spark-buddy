@using Crm.Library.Modularization.Extensions
@inherits Crm.Library.Modularization.CrmViewUserControl

<div role="tabpanel" class="tab-pane animated fadeIn" id="tab-details">
	<pmb-block params="icon: 'lock-outline', caption: 'DataProtectionTitle', context: { site: site }, condition: false">
		<pmbb-view>
			<!-- ko with: site -->
			<!-- ko with: ExtensionValues -->
			<pmbb-view-entry params="caption: 'DataProtectionCompanyName'">
				<span data-bind="text: CompanyName"></span>
				<span class="c-gray" data-bind="translatedText: 'Unspecified', ifnot: CompanyName"></span>
			</pmbb-view-entry>
			<pmbb-view-entry params="caption: 'DataProtectionResponsibleAddress'">
				<span data-bind="text: ResponsibleAddress"></span>
				<span class="c-gray" data-bind="translatedText: 'Unspecified', ifnot: ResponsibleAddress"></span>
			</pmbb-view-entry>
			<pmbb-view-entry params="caption: 'DataProtectionOfficer'">
				<span data-bind="text: DataProtectionOfficer"></span>
				<span class="c-gray" data-bind="translatedText: 'Unspecified', ifnot: DataProtectionOfficer"></span>
			</pmbb-view-entry>
			<!-- /ko -->
			<!-- /ko -->
		</pmbb-view>
	</pmb-block>
	<pmb-block params="icon: 'key', caption: 'Security', context: { site: site }, condition: false">
			<pmbb-view>
				<!-- ko with: site -->
				<!-- ko with: ExtensionValues -->
				<pmbb-view-entry params="caption: 'SecurityMinPasswordStrength'">
					<span data-bind="text: MinPasswordStrength"></span> (<span data-bind="lookupValue: MinPasswordStrength, lookups: $root.lookups.passwordStrengths"></span>)
				</pmbb-view-entry>
				<!-- ko ifnot: window.Main.Settings.UseOpenIdAuthentication -->
				<pmbb-view-entry params="caption: 'MultiFactorAuthentication'">
					<span data-bind="lookupValue: MultiFactorAuthenticationModeKey, lookups: $root.lookups.multiFactorAuthenticationModes"></span>
				</pmbb-view-entry>
				<!-- /ko -->
				<!-- /ko -->
				<!-- /ko -->
			</pmbb-view>
	</pmb-block>
	<pmb-block params="icon: 'file-text', caption: 'Report', context: { site: site }, condition: false">
		<pmbb-view>
			<!-- ko with: site -->
			<!-- ko with: ExtensionValues -->
			<pmbb-view-entry params="caption: 'ReportLogo'">
				<!-- ko if: ReportLogoBase64 -->
				<div class="img-thumbnail-container">
					<img class="img-responsive" data-bind="attr: { src: 'data:image/png;base64,' + ReportLogoBase64() }" />
				</div>
				<!-- /ko -->
				<span class="c-gray" data-bind="translatedText: 'Unspecified', ifnot: ReportLogoBase64"></span>
			</pmbb-view-entry>
			<pmbb-view-entry params="caption: 'ReportFooter'">
				<!-- ko if: ReportFooterImageBase64 -->
				<div class="img-thumbnail-container">
					<img class="img-responsive" data-bind="attr: { src: 'data:image/png;base64,' + ReportFooterImageBase64() }" />
				</div>
				<!-- /ko -->
				<span class="c-gray" data-bind="translatedText: 'Unspecified', ifnot: ReportFooterImageBase64"></span>
			</pmbb-view-entry>
			<pmbb-view-entry params="caption: 'ReportFooterCol1'">
				<span data-bind="text: ReportFooterCol1"></span>
				<span class="c-gray" data-bind="translatedText: 'Unspecified', ifnot: ReportFooterCol1"></span>
			</pmbb-view-entry>
			<pmbb-view-entry params="caption: 'ReportFooterCol2'">
				<span data-bind="text: ReportFooterCol2"></span>
				<span class="c-gray" data-bind="translatedText: 'Unspecified', ifnot: ReportFooterCol2"></span>
			</pmbb-view-entry>
			<pmbb-view-entry params="caption: 'ReportFooterCol3'">
				<span data-bind="text: ReportFooterCol3"></span>
				<span class="c-gray" data-bind="translatedText: 'Unspecified', ifnot: ReportFooterCol3"></span>
			</pmbb-view-entry>
			<!-- /ko -->
			<!-- /ko -->
		</pmbb-view>
	</pmb-block>
	@Html.PluginRenderActions("SiteDetailsTab")
</div>