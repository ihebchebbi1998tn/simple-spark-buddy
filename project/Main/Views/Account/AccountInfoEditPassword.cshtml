<!-- ko ifnot: window.Main.Settings.UseActiveDirectoryAuthenticationService || window.Main.Settings.UseOpenIdAuthentication -->
<pmbb-edit-entry params="caption: 'OldPassword', validationElement: $root.oldPassword">
	<input type="password" class="form-control" data-bind="value: $root.oldPassword">
</pmbb-edit-entry>
<pmbb-edit-entry params="caption: 'NewPassword', validationElement: $root.newPassword">
	<input type="password" autocomplete="new-password" class="form-control" data-bind="textInput: $root.newPassword">
</pmbb-edit-entry>

<!-- ko with: $root.site -->
<!-- ko with: ExtensionValues -->
<pmbb-view-entry>
	<span data-bind="lookupValue: MinPasswordStrength, lookups: $root.lookups.passwordStrengths"></span>
</pmbb-view-entry>
<!-- /ko -->
<!-- /ko -->

<pmbb-edit-entry params="caption: 'ConfirmNewPassword', validationElement: $root.newPassword2">
	<input type="password" autocomplete="new-password" class="form-control" data-bind="textInput: $root.newPassword2">
</pmbb-edit-entry>
<!-- /ko -->