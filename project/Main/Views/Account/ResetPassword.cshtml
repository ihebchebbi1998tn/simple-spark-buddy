@inherits Crm.Library.Modularization.CrmViewPage<Main.ViewModels.CrmModel>
@{
	Layout = "~/Views/Shared/Layout/LoginLayout.cshtml";
}
@using Crm.Library.Globalization.Extensions
@using Main.Extensions

@section TitleContent {
	<title>@(Html.Localize("ResetPassword"))</title>
}

@section MainContent {
	@await Html.PartialAsync("Master/CordovaJs")
	<div id="l-forget-password">
		<div>
			<h4>@(Html.Localize("ForgotPassword"))</h4>
			<div>@(Html.Localize("EnterYourEmail"))</div>
		</div>
		@using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post))
		{
			<div class="fg-line">
				<input type="text" class="form-control indent" id="email" name="email" placeholder="@(Html.Localize("Email"))" />
			</div>
			<div class="has-error">
				<small class="help-block">
					@(Html.RuleViolationMessage())
				</small>
			</div>
			<button id="btn-login" class="btn btn-login btn-primary w-100" type="submit">
				@(Html.Localize("Send"))
			</button>
		}
		<div class="additional-actions">
			<div>
				@(Html.ActionLink(Html.Localize("BackToLogin"), "Login", "Account", new { plugin = "Main" }, new { @class = "btn btn-xs btn-link" }))
			</div>
		</div>
	</div>
}